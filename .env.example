NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/pos_billing_system?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h

# Session
SESSION_SECRET=change_this_to_a_long_random_session_secret

# Cookie
COOKIE_MAX_AGE=28800000

# Default admin (used only by seed script)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@12345
DEFAULT_ADMIN_EMAIL=admin@example.com
