<div class="page-header">
  <div class="page-header-left">
    <h1>Reset Password</h1>
    <p>Set a new password for <strong><%= staffMember.name %></strong></p>
  </div>
  <a href="/admin/staff" class="btn btn-ghost"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div style="max-width:400px">
  <div class="card">
    <% if (errors && errors.length > 0) { %>
    <div class="alert alert-danger mb-16">
      <% errors.forEach(function(e){ %><div><i class="bi bi-dot"></i> <%= e.message %></div><% }) %>
    </div>
    <% } %>

    <div class="alert alert-warning mb-16">
      <i class="bi bi-shield-exclamation"></i>
      The staff member will be logged out and must use the new password.
    </div>

    <form action="/admin/staff/<%= staffMember._id %>/reset-password" method="POST" data-once>
      <div class="form-group">
        <label class="form-label">New Password *</label>
        <input type="password" name="newPassword" class="form-control" required autofocus
               placeholder="Min 6 chars, at least 1 number" />
      </div>
      <div style="display:flex;gap:10px;margin-top:16px">
        <button type="submit" class="btn btn-warning"><i class="bi bi-key"></i> Reset Password</button>
        <a href="/admin/staff" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
