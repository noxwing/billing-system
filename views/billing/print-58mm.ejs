<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receipt - <%= bill.invoiceNo %></title>
  <link rel="stylesheet" href="/css/print.css" />
  <style>
    .item-price { width: 40px; font-size: 9px; }
    .item-total { width: 48px; }
    .item-qty   { width: 40px; }
    .receipt-grand-row { font-size: 13px; }
  </style>
</head>
<body>
<div class="print-preview-page no-print">
  <div class="print-actions">
    <button class="btn-print-now" onclick="window.print()">🖨 Print Now</button>
    <button class="btn-close-print" onclick="window.close()">Close</button>
    <a href="/billing/<%= bill._id %>/print/80mm" style="padding:9px 20px;background:#e5e7eb;color:#111;border-radius:6px;font-size:.875rem;font-weight:600;text-decoration:none">80mm</a>
  </div>
</div>

<div class="receipt-paper receipt-58mm">
  <div class="receipt-wrap">
    <div class="receipt-header">
      <div class="receipt-store-name" style="font-size:13px"><%= settings.storeName %></div>
      <% if (settings.address) { %><div class="receipt-address" style="font-size:9px"><%= settings.address %></div><% } %>
      <% if (settings.phone) { %><div class="receipt-address" style="font-size:9px">Ph: <%= settings.phone %></div><% } %>
      <% if (settings.gstNumber) { %><div class="receipt-gst" style="font-size:9px">GST: <%= settings.gstNumber %></div><% } %>
    </div>

    <div class="receipt-divider"></div>

    <div class="receipt-meta">
      <div class="receipt-meta-row"><span>Inv:</span><span><strong><%= bill.invoiceNo %></strong></span></div>
      <div class="receipt-meta-row"><span>Date:</span><span><%= new Date(bill.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %> <%= new Date(bill.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %></span></div>
      <div class="receipt-meta-row"><span>By:</span><span><%= bill.cashierName %></span></div>
      <% if (bill.customerName) { %><div class="receipt-meta-row"><span>Cust:</span><span><%= bill.customerName %></span></div><% } %>
    </div>

    <div class="receipt-divider"></div>

    <div class="receipt-items-header" style="font-size:9px">
      <span class="item-name">Item</span>
      <span class="item-qty">Qty</span>
      <span class="item-price">Rate</span>
      <span class="item-total">Amt</span>
    </div>
    <div class="receipt-divider-solid"></div>

    <% bill.items.forEach(function(item){ %>
    <div class="receipt-item-row" style="font-size:10px">
      <span class="item-name"><%= item.name %></span>
      <span class="item-qty"><%= formatQty(item.qty, item.unit) %></span>
      <span class="item-price"><%= settings.currencySymbol %><%= item.unitPrice.toFixed(2) %></span>
      <span class="item-total"><%= settings.currencySymbol %><%= item.lineSubtotal.toFixed(2) %></span>
    </div>
    <% }) %>

    <div class="receipt-divider-solid"></div>

    <div class="receipt-totals" style="font-size:10px">
      <% if (bill.discountTotal > 0) { %>
      <div class="receipt-total-row"><span>Discount</span><span>-<%= settings.currencySymbol %><%= bill.discountTotal.toFixed(2) %></span></div>
      <% } %>
      <% if (bill.taxTotal > 0) { %>
      <div class="receipt-total-row"><span>Tax</span><span><%= settings.currencySymbol %><%= bill.taxTotal.toFixed(2) %></span></div>
      <% } %>
    </div>

    <div class="receipt-divider-double"></div>
    <div class="receipt-grand-row"><span>TOTAL</span><span><%= settings.currencySymbol %><%= bill.grandTotal.toFixed(2) %></span></div>
    <div class="receipt-divider"></div>

    <div class="receipt-payment" style="font-size:10px">
      <div class="receipt-meta-row"><span><%= bill.paymentMethod.toUpperCase() %></span><span><%= settings.currencySymbol %><%= bill.grandTotal.toFixed(2) %></span></div>
      <% if (bill.paymentDetails.balance > 0) { %>
      <div class="receipt-meta-row"><span>Change</span><span><%= settings.currencySymbol %><%= bill.paymentDetails.balance.toFixed(2) %></span></div>
      <% } %>
    </div>

    <div class="receipt-divider"></div>
    <div class="receipt-footer" style="font-size:9px"><%= settings.receiptFooterMessage %></div>
  </div>
</div>
</body>
</html>
